{
  "name": "obsidian-agent-gateway",
  "version": "0.1.0",
  "description": "MCP server that uses an Obsidian vault as a middleware gateway between multi-CLI agent workflows (Claude Code, Codex, OpenCode, ...).",
  "type": "module",
  "bin": {
    "obsidian-agent-gateway": "dist/src/index.js"
  },
  "main": "dist/src/index.js",
  "files": [
    "dist",
    "slash-commands",
    "README.md",
    "AGENTS.md",
    "CLAUDE.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/index.js",
    "start:http": "node dist/src/http.js",
    "dev": "tsc --watch",
    "test": "node --test --test-reporter=spec dist/tests/*.test.js",
    "typecheck": "tsc --noEmit",
    "inspect": "npx @modelcontextprotocol/inspector node dist/src/index.js",
    "clean": "rimraf dist"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "obsidian",
    "agent",
    "claude-code",
    "codex",
    "opencode"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "gray-matter": "^4.0.3",
    "write-file-atomic": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/write-file-atomic": "^4.0.3",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20"
  }
}
