# Path to the Obsidian vault used as the gateway storage.
# Default (Windows): D:\working\AgentGateway
# Override if your vault lives elsewhere.
AGENT_GATEWAY_VAULT=D:\working\AgentGateway

# Log level: debug | info | warn | error
AGENT_GATEWAY_LOG_LEVEL=info

# Timezone for human-readable timestamps.
# Use IANA tz name. Default: Asia/Ho_Chi_Minh
AGENT_GATEWAY_TZ=Asia/Ho_Chi_Minh

# HTTP MCP server for ChatGPT Apps local development.
# Run with: npm run start:http
# Then expose with: ngrok http 2091
AGENT_GATEWAY_HTTP_HOST=127.0.0.1
AGENT_GATEWAY_HTTP_PORT=2091

# Breakdown thresholds (line counts).
# Plans shorter than SMALL produce a single task.
# Between SMALL and LARGE, split by H2.
# Above LARGE, split by H2 + H3.
AGENT_GATEWAY_BREAKDOWN_SMALL=800
AGENT_GATEWAY_BREAKDOWN_LARGE=2000
